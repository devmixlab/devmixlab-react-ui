{
  "name": "devmixlab-react-ui",
  "type": "module",
  "version": "1.0.0",
  "main": "./dist/index.esm.js",
  "module": "./dist/index.esm.js",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "dev:tsc": "tsc --watch -p tsconfig.dev.json",
    "dev:dist:tsc": "tsc --watch -p tsconfig.dev.json",
    "type:build": "tsc --emitDeclarationOnly",
    "lint": "eslint src --ext .ts,.tsx",
    "watch:scss": "sass src:dev --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "copy:scss": "cd src && cpy \"**/*.scss\" ../dist --parents",
    "copy:scss:watch": "chokidar \"src/**/*.scss\" -c \"npm run copy:scss\"",
    "generate": "tsx scripts/run-generators.ts",
    "generate:watch": "tsx scripts/watch-generators.ts"
  },
  "peerDependencies": {
    "@headlessui/react": "^2.2.9",
    "clsx": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@rollup/plugin-typescript": "^11.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^6.0.1",
    "chokidar": "^5.0.0",
    "chokidar-cli": "^3.0.0",
    "clsx": "^2.1.1",
    "cpy-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fast-glob": "^3.3.3",
    "jsdom": "^29.0.2",
    "prettier": "^3.7.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rollup": "^3.30.0",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.98.0",
    "sass-embedded": "^1.98.0",
    "tailwindcss": "^3.2.1",
    "tsx": "^4.23.0",
    "typescript": "^5.0.2",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "decimal.js": "^10.6.0"
  }
}
